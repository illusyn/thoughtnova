---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About" description="About Thought Nova" />
	</head>
	<body>
		<Header />
		<main>
			<h1>About</h1>
			<p>
				Thought Nova is a space for ideas worth exploring — reflections on
				teaching, learning, mathematics, and whatever else sparks curiosity.
			</p>
			<p>
				Written by Bill Rishel.
			</p>
		</main>
		<Footer />
	</body>
</html>
